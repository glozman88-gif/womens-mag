# === LLM ===
# Ключ API для вызова Claude.
# Если у вас ключ от самого Anthropic (sk-ant-...), оставьте ANTHROPIC_BASE_URL пустым.
# Если используете ProxyAPI (для российских карт), укажите оба поля:
ANTHROPIC_API_KEY=sk-...
ANTHROPIC_BASE_URL=
# Для ProxyAPI: ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic
ANTHROPIC_MODEL=claude-opus-4-7

# === Логирование ===
LOG_LEVEL=INFO

# Set DRY_RUN=true to run parsers without calling LLM or writing files.
DRY_RUN=false

# === Пути вывода (относительно pipeline/) ===
CONTENT_DIR=../web/src/content/articles
IMAGES_DIR=../web/public/images/articles
IMAGES_URL_PREFIX=/images/articles
