---
import "~/styles/global.css";
import { SITE } from "~/consts";
import SEO from "~/components/SEO.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  article?: {
    publishedAt: Date;
    updatedAt?: Date;
    category: string;
    author: string;
    tags?: string[];
  };
  jsonLd?: Record<string, unknown>;
}

const { title, description, image, type, article, jsonLd } = Astro.props;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,400..700&family=Inter:wght@400;500;600&display=swap"
    />

    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      article={article}
      jsonLd={jsonLd}
    />
  </head>
  <body class="flex flex-col min-h-dvh">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
