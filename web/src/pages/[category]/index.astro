---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import { CATEGORY_META } from "~/content/config";
import { SITE } from "~/consts";

export async function getStaticPaths() {
  const categories = Object.keys(CATEGORY_META) as Array<keyof typeof CATEGORY_META>;
  return categories.map((key) => ({ params: { category: key } }));
}

const { category } = Astro.params as { category: keyof typeof CATEGORY_META };
const meta = CATEGORY_META[category];

const articles = (await getCollection("articles", ({ data }) => !data.draft && data.category === category))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${meta.label} — ${SITE.name}`,
  description: meta.description,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  inLanguage: "ru-RU",
};
---

<BaseLayout title={meta.label} description={meta.description} jsonLd={jsonLd}>
  <section class="container-prose pt-12 pb-8 border-b border-ink/10">
    <p class="kicker">Рубрика</p>
    <h1 class="font-serif text-display mt-2">{meta.label}</h1>
    <p class="mt-4 text-ink/70 max-w-xl">{meta.description}</p>
  </section>

  <section class="container-prose py-section">
    {articles.length === 0 ? (
      <p class="text-ink/60">В этой рубрике пока нет материалов.</p>
    ) : (
      <div class="grid gap-8 md:grid-cols-3">
        {articles.map((entry) => (
          <ArticleCard
            href={`/${entry.data.category}/${entry.slug}`}
            title={entry.data.title}
            description={entry.data.description}
            category={entry.data.category}
            heroImage={entry.data.heroImage}
            heroImageAlt={entry.data.heroImageAlt}
            publishedAt={entry.data.publishedAt}
            variant="medium"
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
