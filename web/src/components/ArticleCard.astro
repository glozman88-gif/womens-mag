---
import { CATEGORY_META } from "~/content/config";
import { url } from "~/utils/url";

export interface Props {
  href: string;
  title: string;
  description?: string;
  category: keyof typeof CATEGORY_META;
  heroImage?: string;
  heroImageAlt?: string;
  publishedAt: Date;
  variant?: "hero" | "large" | "medium" | "small" | "compact";
}

const {
  href,
  title,
  description,
  category,
  heroImage,
  heroImageAlt,
  publishedAt,
  variant = "medium",
} = Astro.props;

const categoryLabel = CATEGORY_META[category]?.label ?? category;

const dateFmt = new Intl.DateTimeFormat("ru-RU", {
  day: "numeric",
  month: "long",
});

const imgAspect = {
  hero: "aspect-[4/3]",
  large: "aspect-[16/10]",
  medium: "aspect-[4/3]",
  small: "aspect-[4/3]",
  compact: "aspect-square",
}[variant];

const titleSize = {
  hero: "text-2xl md:text-3xl lg:text-4xl leading-[1.1]",
  large: "text-xl md:text-2xl leading-tight",
  medium: "text-lg md:text-xl leading-snug",
  small: "text-base leading-snug",
  compact: "text-sm leading-snug",
}[variant];

const isCompact = variant === "compact";
---

<article class="group">
  <a
    href={url(href)}
    class:list={[
      "no-underline block h-full",
      isCompact ? "flex gap-4 items-start" : "flex flex-col",
    ]}
  >
    {heroImage && (
      <div
        class:list={[
          "relative overflow-hidden rounded-2xl bg-sand/40 flex-shrink-0",
          imgAspect,
          isCompact ? "w-28 md:w-32" : "w-full",
        ]}
      >
        <img
          src={url(heroImage)}
          alt={heroImageAlt ?? title}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
        />
      </div>
    )}

    <div class:list={["min-w-0", isCompact ? "flex-1" : heroImage ? "pt-4" : ""]}>
      <div class="flex items-center gap-2 text-xs text-ink/60">
        <span class="kicker">{categoryLabel}</span>
        {!isCompact && <>
          <span aria-hidden="true">·</span>
          <time datetime={publishedAt.toISOString()}>{dateFmt.format(publishedAt)}</time>
        </>}
      </div>

      <h3
        class:list={[
          "mt-1.5 font-serif tracking-tight group-hover:text-terracotta transition-colors line-clamp-3",
          titleSize,
        ]}
      >
        {title}
      </h3>

      {description && (variant === "hero" || variant === "large") && (
        <p class="mt-3 text-ink/70 text-sm md:text-base line-clamp-3">
          {description}
        </p>
      )}
    </div>
  </a>
</article>
