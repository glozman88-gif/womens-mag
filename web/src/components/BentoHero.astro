---
import type { CollectionEntry } from "astro:content";
import ArticleCard from "./ArticleCard.astro";

export interface Props {
  articles: CollectionEntry<"articles">[];
}

const { articles } = Astro.props;

const [hero, ...rest] = articles;
const sidebar = rest.slice(0, 3);
const secondary = rest.slice(3, 7);
---

<section class="container-prose pt-8 md:pt-12 pb-section">
  {hero && (
    <div class="grid gap-6 md:gap-8 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <ArticleCard
          href={`/${hero.data.category}/${hero.slug}`}
          title={hero.data.title}
          description={hero.data.description}
          category={hero.data.category}
          heroImage={hero.data.heroImage}
          heroImageAlt={hero.data.heroImageAlt}
          publishedAt={hero.data.publishedAt}
          variant="hero"
        />
      </div>

      {sidebar.length > 0 && (
        <aside class="flex flex-col gap-6 lg:border-l lg:border-ink/10 lg:pl-8">
          {sidebar.map((entry, i) => (
            <>
              <ArticleCard
                href={`/${entry.data.category}/${entry.slug}`}
                title={entry.data.title}
                category={entry.data.category}
                heroImage={entry.data.heroImage}
                heroImageAlt={entry.data.heroImageAlt}
                publishedAt={entry.data.publishedAt}
                variant="compact"
              />
              {i < sidebar.length - 1 && <hr class="border-ink/10" />}
            </>
          ))}
        </aside>
      )}
    </div>
  )}

  {secondary.length > 0 && (
    <div class="mt-14 pt-14 border-t border-ink/10 grid gap-6 md:gap-8 md:grid-cols-2 lg:grid-cols-4">
      {secondary.map((entry) => (
        <ArticleCard
          href={`/${entry.data.category}/${entry.slug}`}
          title={entry.data.title}
          category={entry.data.category}
          heroImage={entry.data.heroImage}
          heroImageAlt={entry.data.heroImageAlt}
          publishedAt={entry.data.publishedAt}
          variant="medium"
        />
      ))}
    </div>
  )}
</section>
