---
import { SITE, NAV } from "~/consts";
const current = Astro.url.pathname;
---

<header class="border-b border-ink/10 bg-cream/80 backdrop-blur sticky top-0 z-40">
  <div class="container-prose flex items-center justify-between py-5">
    <a href="/" class="no-underline flex items-baseline gap-2" aria-label={SITE.name}>
      <span class="font-serif text-3xl tracking-tight italic">{SITE.name}</span>
      <span class="hidden md:inline text-xs text-ink/50 uppercase tracking-[0.2em]">
        {SITE.tagline}
      </span>
    </a>

    <nav class="hidden md:block">
      <ul class="flex items-center gap-6 text-sm">
        {NAV.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={[
                "no-underline hover:text-terracotta transition-colors",
                current.startsWith(href) && "text-terracotta",
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      type="button"
      aria-label="Открыть меню"
      class="md:hidden p-2 -mr-2"
      data-menu-toggle
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <nav class="md:hidden border-t border-ink/10 hidden" data-mobile-menu>
    <ul class="container-prose py-4 grid gap-3 text-base">
      {NAV.map(({ label, href }) => (
        <li>
          <a href={href} class="no-underline block py-1">{label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
