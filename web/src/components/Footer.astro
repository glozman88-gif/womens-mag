---
import { SITE, NAV } from "~/consts";
import { url } from "~/utils/url";
const year = new Date().getFullYear();
---

<footer class="border-t border-ink/10 mt-section">
  <div class="container-prose py-14 grid gap-10 md:grid-cols-3">
    <div>
      <div class="font-serif text-2xl italic">{SITE.name}</div>
      <p class="text-sm text-ink/70 mt-3 max-w-sm">{SITE.description}</p>
    </div>

    <div>
      <div class="kicker mb-3">Рубрики</div>
      <ul class="grid gap-2 text-sm">
        {NAV.map(({ label, href }) => (
          <li><a href={url(href)} class="no-underline hover:text-terracotta">{label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <div class="kicker mb-3">Информация</div>
      <ul class="grid gap-2 text-sm">
        <li><a href={url("/about")} class="no-underline hover:text-terracotta">О проекте</a></li>
        <li><a href={url("/privacy")} class="no-underline hover:text-terracotta">Конфиденциальность</a></li>
        <li><a href={url("/contacts")} class="no-underline hover:text-terracotta">Контакты</a></li>
        <li><a href={url("/rss.xml")} class="no-underline hover:text-terracotta">RSS</a></li>
      </ul>
    </div>
  </div>
  <div class="container-prose pb-10 text-xs text-ink/50 flex flex-wrap gap-2 justify-between">
    <span>© {year} {SITE.name}</span>
    <span>Сайт содержит материалы 18+</span>
  </div>
</footer>
